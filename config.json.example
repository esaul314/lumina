{
  "port": 5000,
  "alertEmail": "admin@localhost",
  "location": {
    "lat": 0,
    "lon": 0,
    "city": "Your City",
    "regionName": "Your Region",
    "country": "Your Country"
  },
  "ecowitt": {
    "enabled": false,
    "baseUrl": "http://ecowitt.local",
    "pollIntervalMs": 60000,
    "timeoutMs": 3000,
    "units": {
      "temperature": "C",
      "pressure": "hPa",
      "wind": "km/h",
      "rain": "mm",
      "light": "lux"
    }
  },
  "sensorHistory": {
    "enabled": true,
    "databasePath": "sensor_history.db",
    "limit": 168
  }
}
