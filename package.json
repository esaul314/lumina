{
  "name": "lumina",
  "version": "1.0.0",
  "description": "Lumina Ambient Screensaver & Smart Display",
  "main": "server.js",
  "scripts": {
    "server": "node server.js",
    "client": "npm run dev --prefix client",
    "dev": "npm run server & npm run client",
    "install-all": "npm install && npm install --prefix client",
    "lint": "eslint . --ext .js,.jsx --ignore-pattern client/dist --ignore-pattern node_modules",
    "lint:fix": "eslint . --ext .js,.jsx --fix --ignore-pattern client/dist --ignore-pattern node_modules",
    "test": "node run-tests.js && node test_sensor_adapters.js",
    "test:integration": "node test_split_sync.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.5"
  }
}
